{
  "name": "Go Mega Power",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.23",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "golang.gopls",
        "ms-vscode.hexeditor",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "tamasfe.even-better-toml",
        "fill-labs.dependi",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.goroot": "/usr/local/go",
        "go.formatTool": "gofumpt",
        "go.lintTool": "golangci-lint",
        "go.testFlags": ["-v"],
        "editor.formatOnSave": true,
        "editor.inlayHints.enabled": "on",
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "nonFreePackages": true
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    }
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ripgrep fd-find bat git-delta hyperfine curl make gcc g++ && go install github.com/air-verse/air@latest && go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && go install golang.org/x/tools/cmd/goimports@latest && go install mvdan.cc/gofumpt@latest && go install honnef.co/go/tools/cmd/staticcheck@latest && go install github.com/go-delve/delve/cmd/dlv@latest && go install github.com/kyoh86/richgo@latest && echo '🚀 Go Mega Power Environment loaded!'",

  "postStartCommand": "go version && golangci-lint --version && air --version",

  "containerEnv": {
    "GO111MODULE": "on",
    "GOPROXY": "https://proxy.golang.org,direct",
    "GOSUMDB": "sum.golang.org",
    "CGO_ENABLED": "1"
  },

  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/go/pkg/mod,target=/go/pkg/mod,type=bind,consistency=cached"
  ],

  "forwardPorts": [8080, 3000, 5000, 5432, 6379],
  "portsAttributes": {
    "8080": { "label": "App", "onAutoForward": "notify" }
  }
}
