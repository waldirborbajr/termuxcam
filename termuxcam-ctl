#!/bin/bash
# =============================================
# termuxcam - Service Control Script
# For manual maintenance: start, stop, restart, status
# =============================================

set -euo pipefail

SERVICE_NAME="termuxcam"
SERVICE_DIR="$HOME/.termux/service/$SERVICE_NAME"
LOG_FILE="$HOME/camera_captures/capture.log"

usage() {
    cat <<EOF
Usage: $(basename "$0") {start|stop|restart|status|log}

  start    Start the termuxcam service
  stop     Stop the termuxcam service
  restart  Restart the termuxcam service
  status   Show current service status
  log      Show the last 20 lines of the capture log

Examples:
  $(basename "$0") stop      # pause captures for maintenance
  $(basename "$0") start     # resume captures
  $(basename "$0") restart   # apply a config change without rebuilding
EOF
}

check_prereqs() {
    if ! command -v sv >/dev/null 2>&1; then
        echo "❌ 'sv' command not found. Is termux-services installed and is SVDIR set?"
        exit 1
    fi

    if [ ! -d "$SERVICE_DIR" ]; then
        echo "❌ Service directory not found: $SERVICE_DIR"
        echo "   Run the installation step first."
        exit 1
    fi
}

do_start() {
    echo "▶️  Starting $SERVICE_NAME..."
    sv up "$SERVICE_NAME"
    sleep 1
    sv status "$SERVICE_NAME"
}

do_stop() {
    echo "⏹  Stopping $SERVICE_NAME..."
    sv down "$SERVICE_NAME"
    sleep 1
    sv status "$SERVICE_NAME"
}

do_restart() {
    echo "🔄 Restarting $SERVICE_NAME..."
    sv restart "$SERVICE_NAME"
    sleep 2
    sv status "$SERVICE_NAME"
}

do_status() {
    echo "📊 Status of $SERVICE_NAME:"
    sv status "$SERVICE_NAME"
}

do_log() {
    echo "📝 Last 20 lines of capture log:"
    if [ -f "$LOG_FILE" ]; then
        tail -n 20 "$LOG_FILE"
    else
        echo "Log file not found: $LOG_FILE"
    fi
}

main() {
    if [ $# -ne 1 ]; then
        usage
        exit 1
    fi

    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        start|stop|restart|status|log)
            check_prereqs
            "do_$1"
            ;;
        *)
            echo "❌ Unknown command: $1"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"